# Copy this file to .env and fill in real values. .env is git-ignored.

# --- Broker: MetaTrader5 (Windows host required, see docs/ARCHITECTURE.md) ---
MT5_LOGIN=00000000
MT5_PASSWORD=change-me
MT5_SERVER=YourBroker-Live
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# --- Safety gate: required to be exactly "yes" for --mode live to start ---
CHRONOSCALP_CONFIRM_LIVE=no

# --- Kill switch: set to "yes" or create data/state/STOP_TRADING to halt entries ---
CHRONOSCALP_STOP_TRADING=no

# --- Optional: alerting (Phase B — Telegram / Discord) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# --- Optional: economic calendar API for the news filter (Phase 3) ---
# If left empty, filters/news_filter.py falls back to the manual event list
# in config/news_events.yaml
NEWS_API_KEY=

# --- Optional: error tracking ---
SENTRY_DSN=

# --- Environment ---
CHRONOSCALP_ENV=development
LOG_LEVEL=INFO
